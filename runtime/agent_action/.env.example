# Obrigatório para rodar inferência com Gemini via Google ADK.
#
# 1) Copie este arquivo para .env na MESMA pasta:
#    cp .env.example .env
# 2) Abra .env e coloque uma GOOGLE_API_KEY válida (Google AI Studio / credenciais do projeto).
# 3) Nunca commite o arquivo .env (ele já está listado no .gitignore).

GOOGLE_API_KEY=cole_sua_chave_aqui

GOOGLE_GENAI_USE_VERTEXAI=False
