# Validação offline do agent_spec.json (transpiler + JSON Schema).
FROM python:3.12-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY transpiler/requirements.txt /tmp/requirements-transpiler.txt
RUN pip install --upgrade pip \
    && pip install -r /tmp/requirements-transpiler.txt

COPY transpiler/ /app/transpiler/
COPY examples/agent_spec.json examples/agent_spec.schema.json /app/examples/

RUN groupadd --gid 10004 labspec \
    && useradd --uid 10004 --gid labspec --no-create-home --shell /usr/sbin/nologin labspec \
    && chown -R labspec:labspec /app

USER labspec

ENV PYTHONPATH=/app

# Termina após validar (adequado a `docker compose run validate-spec`)
CMD ["python", "transpiler/validate_spec.py", "examples/agent_spec.json"]
