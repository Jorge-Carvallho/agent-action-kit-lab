# Servidor MCP OCR (SSE) — Tesseract + por; PII em security/.
FROM python:3.12-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        curl \
        tesseract-ocr \
        tesseract-ocr-por \
        tesseract-ocr-eng \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY docker/requirements.txt /tmp/requirements-docker.txt
RUN pip install --upgrade pip setuptools wheel \
    && pip install -r /tmp/requirements-docker.txt

COPY mcp_ocr/ /app/mcp_ocr/
COPY security/ /app/security/

RUN groupadd --gid 10003 labocr \
    && useradd --uid 10003 --gid labocr --no-create-home --shell /usr/sbin/nologin labocr \
    && chown -R labocr:labocr /app

USER labocr

EXPOSE 3100

HEALTHCHECK --interval=20s --timeout=5s --start-period=25s --retries=5 \
    CMD curl -fsS "http://127.0.0.1:3100/health" >/dev/null || exit 1

CMD ["python", "-m", "mcp_ocr"]
